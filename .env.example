# EmailJS Configuration
# Get these values from your EmailJS account (https://www.emailjs.com/)

# For local development only - these values are not used in production
# Production deployment uses GitHub repository secrets instead
REACT_APP_EMAILJS_SERVICE_ID=your_service_id_here
REACT_APP_EMAILJS_TEMPLATE_ID=your_template_id_here
REACT_APP_EMAILJS_PUBLIC_KEY=your_public_key_here

# For production deployment, configure these as GitHub repository secrets:
# - EMAILJS_SERVICE_ID
# - EMAILJS_TEMPLATE_ID  
# - EMAILJS_PUBLIC_KEY
#
# Social Links
VITE_INSTAGRAM_URL=https://instagram.com/yourprofile
VITE_YOUTUBE_URL=https://youtube.com/@yourchannel

# Contact Info
VITE_STUDIO_EMAIL=ola@yourdomain.com
VITE_STUDIO_ADDRESS=Street Name, Number, City, State
VITE_GOOGLE_MAPS_URL=https://www.google.com/maps?...
